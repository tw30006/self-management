# ── Google Identity Services ──────────────────────────────────────────────────
# 前往 https://console.cloud.google.com/apis/credentials 建立 OAuth 2.0 用戶端 ID
# 類型選「Web 應用程式」，並在「已授權的 JavaScript 來源」加入開發用網址，例如：
#   http://localhost:5173
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# 限定只允許此 email 登入（只有你自己的 Google 帳戶）
# 若留空，所有 Google 帳號皆可登入
VITE_ALLOWED_EMAIL=you@gmail.com

# ── API ───────────────────────────────────────────────────────────────────────
# 後端 API 的 base URL（開發時預設為 /api，由 Vite proxy 轉發）
VITE_API_BASE_URL=/api
