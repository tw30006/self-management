FROM node:20-alpine

WORKDIR /app

# Build context is repository root, so backend files are copied via backend/ prefix.
COPY backend/package*.json ./

# 確保使用穩定的 npm 版本（避免在 CI 或主機上執行全域 `npm update -g npm` 導致的缺失）
RUN corepack enable \
	&& corepack prepare npm@9.8.1 --activate \
	&& npm install

COPY backend/ ./

RUN npx prisma generate

EXPOSE 8080

CMD ["npm", "run", "dev"]